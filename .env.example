# ThreatSense Environment Configuration
# Copy this file to .env and update with your settings

# Application
APP_NAME=ThreatSense
APP_ENV=development
DEBUG=True

# Database
DATABASE_URL=sqlite:///./threats.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/threatsense

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# AI Models
MEDIAPIPE_MODEL_COMPLEXITY=1  # 0=lite, 1=full, 2=heavy
YOLO_MODEL_NAME=yolov8m.pt    # nano, small, medium, large, extra
YOLO_CONFIDENCE=0.45
YOLO_IOU=0.5

# Detection Thresholds
FALL_ASPECT_RATIO=0.8
FALL_COOLDOWN_MS=5000
SHOPLIFTING_COOLDOWN_MS=3000
ASSAULT_COOLDOWN_MS=4000

# GPU
USE_GPU=True
GPU_DEVICE=0  # GPU device index

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/threatsense.log
LOG_MAX_BYTES=104857600  # 100MB
LOG_BACKUP_COUNT=5

# Monitoring
ENABLE_METRICS=True
METRICS_PORT=8001

# Redis (optional, for distributed caching)
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=False

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Storage
STORAGE_PATH=./storage
MODEL_PATH=./models
